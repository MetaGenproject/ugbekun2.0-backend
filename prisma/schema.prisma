  @@unique([arenaId, studentId])
  @@index([arenaId])
  @@map("trivia_arena_participants")
}

// ─────────────────────────────────────────────────────────────────────────────
// AI LEARNING COMPANION SESSIONS
// ─────────────────────────────────────────────────────────────────────────────

model AiCompanionSession {
  id        Int      @id @default(autoincrement())
  studentId Int      @map("student_id")
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  title     String?
  messages  Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([studentId])
  @@map("ai_companion_sessions")
}

model QuestionBank {
  id             Int       @id @default(autoincrement())
  questionText   String    @map("question_text") @db.Text
  questionType   String    @default("mcq") @map("question_type") // mcq | theory
  options        Json?     @map("options") // Array of options, e.g. ["Option A", "Option B", ...]
  correctOption  String?   @map("correct_option") // E.g. "A", "B", etc. or index/text
  marks          Float     @default(1.0) @map("marks")
  subjectId      Int       @map("subject_id")
  classId        Int?      @map("class_id") // Optional target class reference
  branchId       Int       @map("branch_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @updatedAt @map("updated_at")

  subject        Subject   @relation(fields: [subjectId], references: [id])
  class          Class?    @relation(fields: [classId], references: [id])

  @@index([subjectId, branchId])
  @@map("question_bank")
}

model Event {
  id          Int       @id @default(autoincrement())
  title       String
  description String?   @db.Text
  startDate   DateTime  @map("start_date")
  endDate     DateTime? @map("end_date")
  branchId    Int?      @map("branch_id")
  sessionId   Int?      @map("session_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  @@index([branchId, sessionId])
  @@map("event")
}
