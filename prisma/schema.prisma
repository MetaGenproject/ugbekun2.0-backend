  @@map("gamification_configs")
}

// ─────────────────────────────────────────────────────────────────────────────
// GAMIFICATION ENGINE LEDGER & LEADERBOARD
// ─────────────────────────────────────────────────────────────────────────────

model GamificationLedger {
  id              Int      @id @default(autoincrement())
  actorType       String   @map("actor_type") // "TEACHER" | "STUDENT"
  actorId         Int      @map("actor_id") // ID referencing Teacher or Student
  points          Int // Positive for credit (+XP), negative for debit/correction
  actionType      String   @map("action_type") // e.g. "ATTENDANCE_9AM", "LESSON_PLAN_EARLY"
  referenceEntity String?  @map("reference_entity") // e.g. "Attendance", "HomeworkSubmission"
  referenceId     Int?     @map("reference_id") // ID of the trigger record
  idempotencyKey  String   @unique @map("idempotency_key") // Unique hash: SHA256(actorType+actorId+actionType+referenceId)
  createdAt       DateTime @default(now()) @map("created_at")
  metadata        Json?    @map("metadata") // Stores context: submission delay, timestamps, streak number

  @@index([actorType, actorId])
  @@index([createdAt])
  @@map("gamification_ledger")
}

model LeaderboardCache {
  id         Int      @id @default(autoincrement())
  entityType String   @map("entity_type") // "TEACHER" | "STUDENT"
  entityId   Int      @map("entity_id") // Teacher.id or Student.id
  points     Int      @default(0)
  rank       Int      @default(0)
  period     String // "DAILY" | "WEEKLY" | "MONTHLY" | "TERMLY" | "ALL_TIME"
  branchId   Int      @map("branch_id")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([entityType, entityId, period, branchId])
  @@index([entityType, period, points(sort: Desc)])
  @@map("leaderboard_caches")
}

// ─────────────────────────────────────────────────────────────────────────────
// INTERNAL TRIVIA & ACHIEVEMENTS
// ─────────────────────────────────────────────────────────────────────────────

model TriviaQuestion {
  id              Int                @id @default(autoincrement())
  questionText    String             @map("question_text") @db.Text
  options         Json               // Array of choices: e.g., ["A", "B", "C", "D"]
  correctOption   Int                @map("correct_option")   // Correct index: 0 to 3
  timeLimitSeconds Int               @default(15) @map("time_limit_seconds")
  points          Int                @default(10)             // Base XP awarded for correct answer
  difficulty      String             @default("MEDIUM")       // EASY | MEDIUM | HARD
  subjectId       Int?               @map("subject_id")       // Optional: link to curriculum subject
  classId         Int?               @map("class_id")         // Optional: target difficulty tier
  active          Boolean            @default(true)
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
