// ─────────────────────────────────────────────────────────────────────────────
// PREDICTIVE ATTRITION RADER & INTERVENTIONS
// ─────────────────────────────────────────────────────────────────────────────

model StudentAttritionRisk {
  id               Int      @id @default(autoincrement())
  studentId        Int      @unique @map("student_id")
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  attendanceScore  Float    @map("attendance_score") // 0.0 to 1.0 (Higher is riskier)
  academicScore    Float    @map("academic_score")    // 0.0 to 1.0 (Decline velocity)
  financialScore   Float    @map("financial_score")   // 0.0 to 1.0 (Outstanding balance backlog)
  sentimentScore   Float    @map("sentiment_score")   // 0.0 to 1.0 (Narrative negative spike)
  compositeDrift   Float    @map("composite_drift")   // 0.0 to 1.0 (Weighted sum)
  
  riskLevel        String   @map("risk_level")        // "LOW" (drift < 0.4), "MEDIUM" (0.4 <= drift < 0.7), "HIGH" (drift >= 0.7)
  isIsolated       Boolean  @default(false) @map("is_isolated")
  
  lastEvaluatedAt  DateTime @default(now()) @map("last_evaluated_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  
  alerts           InterventionAlert[]

  @@index([riskLevel])
  @@map("student_attrition_risks")
}

model InterventionAlert {
  id               Int                  @id @default(autoincrement())
  riskId           Int                  @map("risk_id")
  risk             StudentAttritionRisk @relation(fields: [riskId], references: [id], onDelete: Cascade)
  
  teacherId        Int                  @map("teacher_id")
  teacher          Teacher              @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  
  status           String               @default("PENDING") @map("status") // PENDING, ACTIVE, RESOLVED, DISMISSED
  parentPlan       String?              @db.Text @map("parent_plan")       // AI Pre-drafted remediation roadmap
  remediationSteps Json?                @map("remediation_steps")          // Dynamic list of action items
  
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  @@index([status])
  @@map("intervention_alerts")
}

